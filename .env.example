# Copy this file to .env and fill in values for local development.
# .env is excluded from git — never commit real secrets.

# Leave blank to use local SQLite (fantasy.db).
# Set to a PostgreSQL URL to use Postgres locally.
DATABASE_URL=

# A long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-production

# League calendar (defaults already set in config/settings.py)
# LEAGUE_START=2026-04-14
# LEAGUE_END=2026-06-19
